}

// ─────────────────────────────────────────────
// INDICATORS
// ─────────────────────────────────────────────

function ema(closes, period) {
  const k = 2 / (period + 1);
  let e = closes[0];
  for (let i = 1; i < closes.length; i++) e = closes[i] * k + e * (1 - k);
  return e;
}

function emaArr(closes, period) {
  const k = 2 / (period + 1);
  const out = [closes[0]];
  for (let i = 1; i < closes.length; i++) out.push(closes[i] * k + out[i-1] * (1 - k));
  return out;
}

function bollingerWidth(closes, period = 20) {
  if (closes.length < period) return { width: 0, squeeze: false };
  const recent = closes.slice(-period);
  const mean = recent.reduce((a,b) => a+b, 0) / period;
  const std = Math.sqrt(recent.reduce((s,c) => s + (c-mean)**2, 0) / period);
  const width = (2 * 2 * std) / mean; // normalized
  return { width, mean, std, upper: mean + 2*std, lower: mean - 2*std };
}

function atr14(candles) {
  if (candles.length < 15) return 0;
  const trs = [];
  for (let i = 1; i < candles.length; i++) {
    const hl = candles[i].h - candles[i].l;
    const hc = Math.abs(candles[i].h - candles[i-1].c);
    const lc = Math.abs(candles[i].l - candles[i-1].c);
    trs.push(Math.max(hl, hc, lc));
  }
  const last14 = trs.slice(-14);
  return last14.reduce((a,b) => a+b, 0) / 14;
}

// Hurst exponent via R/S analysis
function hurstRS(closes) {
  if (closes.length < 20) return 0.5;
  const returns = [];
  for (let i = 1; i < closes.length; i++) returns.push(Math.log(closes[i] / closes[i-1]));
  const n = returns.length;
  const mean = returns.reduce((a,b) => a+b, 0) / n;
  const deviations = returns.map(r => r - mean);
  const cumDev = [];
  let cum = 0;
  for (const d of deviations) { cum += d; cumDev.push(cum); }
  const R = Math.max(...cumDev) - Math.min(...cumDev);
  const S = Math.sqrt(returns.reduce((s,r) => s + (r-mean)**2, 0) / n);
  if (S === 0) return 0.5;
  const rs = R / S;
  return Math.log(rs) / Math.log(n);
}

function thirtyDayHighLow(dailyCandles) {
  const last30 = dailyCandles.slice(-30);
  const high = Math.max(...last30.map(c => c.h));
  const low = Math.min(...last30.map(c => c.l));
  return { high, low };
}

function volumeRatio(dailyCandles) {
  if (dailyCandles.length < 31) return 1;
  const baseline30 = dailyCandles.slice(-31, -1).map(c => c.vol);
  const avg = baseline30.reduce((a,b) => a+b, 0) / baseline30.length;
  const lastVol = dailyCandles[dailyCandles.length - 1].vol;
  return avg > 0 ? lastVol / avg : 1;
}

// BB squeeze: current width vs 2-week average width
function detectBBSqueeze(dailyCandles, lookback = 14) {
  if (dailyCandles.length < lookback + 20) return { squeeze: false, days: 0 };
  const closes = dailyCandles.map(c => c.c);
  // compute width for each day in lookback
  const widths = [];
  for (let i = dailyCandles.length - lookback; i <= dailyCandles.length; i++) {
    const slice = closes.slice(Math.max(0, i - 20), i);
    if (slice.length >= 10) widths.push(bollingerWidth(slice).width || 0);
  }
  const avgWidth = widths.reduce((a,b) => a+b, 0) / widths.length;
  const curWidth = bollingerWidth(closes).width;
  const squeeze = curWidth < avgWidth;
  // count consecutive squeeze days
  let days = 0;
  for (let i = dailyCandles.length - 1; i >= 0; i--) {
    const slice = closes.slice(Math.max(0, i - 20), i+1);
    if (slice.length < 10) break;
    const w = bollingerWidth(slice).width;
    if (w < avgWidth) days++; else break;
  }
  return { squeeze, days, curWidth, avgWidth };
}

// ─────────────────────────────────────────────
// WEEKLY EMA (from daily candles — approximate)
// ─────────────────────────────────────────────

function weeklyEMA20fromDaily(dailyCandles) {
  // Resample daily to weekly (last close of each 5-day block)
  const weekly = [];
  for (let i = 4; i < dailyCandles.length; i += 5) weekly.push(dailyCandles[i].c);
  if (weekly.length < 5) return dailyCandles[dailyCandles.length - 1].c;
  return ema(weekly, Math.min(20, weekly.length));
}

// ─────────────────────────────────────────────
// MAIN SCAN LOGIC
// ─────────────────────────────────────────────

let scanResults = [];
let filteredOut = [];

async function runScan() {
  const apiKey = document.getElementById('apiKey').value.trim();
  const limit = parseInt(document.getElementById('assetLimit').value);
  const fundingCutoff = parseFloat(document.getElementById('fundingCutoff').value);
  const hurstThresh = parseFloat(document.getElementById('hurstThreshold').value);

  if (!apiKey || !apiKey.startsWith('sk-ant-')) {
    showError('Please enter a valid Anthropic API key (starts with sk-ant-)');
    return;
  }

  // Reset UI
  document.getElementById('errorBox').classList.remove('active');
  document.getElementById('progressSection').classList.add('active');
  document.getElementById('progressLog').innerHTML = '';
  document.getElementById('resultsSection').classList.remove('active');
  document.getElementById('metricsRow').style.display = 'none';
  document.getElementById('setupsGrid').innerHTML = '';
  document.getElementById('filteredChips').innerHTML = '';
  document.getElementById('scanTableBody').innerHTML = '';
  document.getElementById('aiOutput').innerHTML = '<div class="ai-thinking"><span>Awaiting scan data</span></div>';
  document.getElementById('scanBtn').disabled = true;
  document.getElementById('apiDot').style.cssText = 'background:var(--yellow);animation:pulse 2s infinite;box-shadow:0 0 8px var(--yellow)';
  document.getElementById('dataDot').style.cssText = 'background:var(--yellow);animation:pulse 2s infinite;box-shadow:0 0 8px var(--yellow)';

  scanResults = [];
  filteredOut = [];

  try {
    // ── Step 1: Fetch top pairs
    setProgress(5, `Fetching top ${limit} USDT perpetual pairs from OKX...`);
    const pairs = await getTopPairs(limit);
    log(`✓ Retrieved ${pairs.length} pairs`, 'ok');
    document.getElementById('dataDot').style.cssText = 'background:var(--green);animation:pulse 2s infinite;box-shadow:0 0 8px var(--green)';

    // ── Step 2: Analyze each pair
    for (let i = 0; i < pairs.length; i++) {
      const pair = pairs[i];
      const pct = 5 + (i / pairs.length) * 70;
      setProgress(pct, `Analyzing ${pair.instId}...`);

      try {
        // Fetch candles
        const [daily, h4] = await Promise.all([
          getCandles(pair.instId, '1D', 90),
          getCandles(pair.instId, '4H', 60),
        ]);

        if (daily.length < 30) { filteredOut.push({ ticker: pair.instId.replace('-USDT-SWAP',''), reason: 'Insufficient history' }); continue; }

        const closes = daily.map(c => c.c);
        const currentPrice = closes[closes.length - 1];

        // Indicators
        const { high: h30, low: l30 } = thirtyDayHighLow(daily);
        const breakHigh = currentPrice >= h30 * 0.995; // within 0.5% of 30d high
        const breakLow = currentPrice <= l30 * 1.005;
        const signal = breakHigh ? 'LONG' : breakLow ? 'SHORT' : null;
        if (!signal) { filteredOut.push({ ticker: pair.instId.replace('-USDT-SWAP',''), reason: 'No 30D break' }); continue; }

        const ema50d = ema(closes, Math.min(50, closes.length));
        const wEma20 = weeklyEMA20fromDaily(daily);
        const emaOk = signal === 'LONG'
          ? (currentPrice > ema50d && currentPrice > wEma20)
          : (currentPrice < ema50d && currentPrice < wEma20);
        if (!emaOk) { filteredOut.push({ ticker: pair.instId.replace('-USDT-SWAP',''), reason: `EMA fail (${signal})` }); continue; }

        const hurst = hurstRS(closes.slice(-60));
        if (hurst < hurstThresh) { filteredOut.push({ ticker: pair.instId.replace('-USDT-SWAP',''), reason: `H=${hurst.toFixed(2)}<${hurstThresh}` }); continue; }

        const fundingRate = await getFundingRate(pair.instId);
        await sleep(50); // gentle rate limiting
        if (Math.abs(fundingRate) > fundingCutoff) { filteredOut.push({ ticker: pair.instId.replace('-USDT-SWAP',''), reason: `Funding ${fundingRate.toFixed(3)}%` }); continue; }

        const bb = detectBBSqueeze(daily);
        const volRatio = volumeRatio(daily);
        const atrVal = atr14(daily);
        const bbStats = bollingerWidth(closes);

        // Alpha vs BTC (simplified: 7d return comparison)
        const last7 = closes.slice(-8);
        const asset7dReturn = (last7[last7.length-1] / last7[0] - 1) * 100;

        scanResults.push({
          ticker: pair.instId.replace('-USDT-SWAP', ''),
          instId: pair.instId,
          signal,
          price: currentPrice,
          h30, l30,
          hurst,
          bbSqueeze: bb.squeeze,
          bbSqueezeDays: bb.days,
          volRatio,
          fundingRate,
          atr: atrVal,
          asset7dReturn,
          bbMid: bbStats.mean,
          ema50d,
          wEma20,
        });

        log(`✓ ${pair.instId.replace('-USDT-SWAP','')} | ${signal} | H=${hurst.toFixed(2)} | Vol×${volRatio.toFixed(1)} | Fund=${fundingRate.toFixed(3)}%`, 'ok');

      } catch (e) {
        log(`⚠ ${pair.instId}: ${e.message}`, 'warn');
        filteredOut.push({ ticker: pair.instId.replace('-USDT-SWAP',''), reason: 'Data error' });
      }

      await sleep(80); // gentle rate limiting
    }

    setProgress(78, `Scan complete. ${scanResults.length} pairs passed all filters.`);

    // ── Step 3: Render scan table
    renderScanTable(scanResults, filteredOut);

    // ── Step 4: Call Claude API
    setProgress(80, `Sending ${scanResults.length} candidates to Claude for analysis...`);
    document.getElementById('aiOutput').innerHTML = `
      <div class="ai-thinking">
        <span>Claude is analyzing your setups</span>
        <div class="thinking-dots"><span></span><span></span><span></span></div>
      </div>`;

    const aiResult = await callClaudeAnalysis(apiKey, scanResults, hurstThresh, fundingCutoff);
    document.getElementById('aiOutput').textContent = aiResult;
    document.getElementById('aiModel').textContent = 'claude-sonnet-4-20250514';
    document.getElementById('apiDot').style.cssText = 'background:var(--green);animation:pulse 2s infinite;box-shadow:0 0 8px var(--green)';

    setProgress(95, 'Parsing setups...');
    parseAndRenderSetups(aiResult, scanResults);

    setProgress(100, 'Done.');
    document.getElementById('lastScanTime').textContent = new Date().toLocaleTimeString();

    // Metrics
    document.getElementById('mScanned').textContent = pairs.length;
    document.getElementById('mPassed').textContent = scanResults.length;
    document.getElementById('mLong').textContent = scanResults.filter(r => r.signal==='LONG').length;
    document.getElementById('mShort').textContent = scanResults.filter(r => r.signal==='SHORT').length;
    document.getElementById('metricsRow').style.display = 'grid';
    document.getElementById('resultsSection').classList.add('active');

  } catch (err) {
    showError('Scan error: ' + err.message);
    log('SCAN FAILED: ' + err.message, 'err');
    document.getElementById('dataDot').style.cssText = 'background:var(--red);box-shadow:0 0 8px var(--red);animation:none';
  } finally {
    document.getElementById('scanBtn').disabled = false;
  }
}

// ─────────────────────────────────────────────
// CLAUDE API CALL
// ─────────────────────────────────────────────

async function callClaudeAnalysis(apiKey, candidates, hurstThresh, fundingCutoff) {
  // Build data summary for prompt
  const dataBlock = candidates.map((r, i) => `
${i+1}. ${r.ticker} | ${r.signal}
   Price: $${r.price.toFixed(4)} | 30D ${r.signal==='LONG'?'High':'Low'}: $${r.signal==='LONG'?r.h30.toFixed(4):r.l30.toFixed(4)}
   Hurst(60D): ${r.hurst.toFixed(3)} | BB Squeeze: ${r.bbSqueeze ? 'YES ('+r.bbSqueezeDays+' days)' : 'NO'}
   Volume Ratio (vs 30D baseline): ${r.volRatio.toFixed(2)}x | Funding Rate: ${r.fundingRate.toFixed(4)}%
   ATR(14): ${r.atr.toFixed(4)} | 7D Return: ${r.asset7dReturn.toFixed(2)}% | EMA50D: $${r.ema50d.toFixed(4)}
`).join('');

  const prompt = `Role: Senior Crypto Quantitative Analyst.
Objective: Identify 3 high-probability setups for a fixed 10-day holding period from the candidates below, which have already been pre-filtered by a live scanner.

PRE-FILTERED CANDIDATES (passed all hard gates):
${dataBlock}

Filters already applied:
- 30-day High/Low breach (within 72h)
- EMA confluence: above/below Daily 50 EMA and Weekly 20 EMA
- Hurst Exponent > ${hurstThresh} (trend persistence confirmed)
- Funding rate within ±${fundingCutoff}%

1. SCORING (The "Swing" Potential):
   * Compression: Prioritize tokens exiting a Bollinger Band Squeeze (squeeze days ≥ 7)
   * Relative Strength vs BTC: Asset must show 7-day Alpha of ±5% vs Bitcoin
   * Volume Profile: Prioritize volume surges ≥ 2.5× the 30-day baseline

2. OUTPUT FORMAT (for each of the 3 selected setups):
   * Ticker & Signal: [TICKER] | [LONG/SHORT] | [CONVICTION 1-10]
   * Technical Thesis: Brief quantitative trigger (EMA/Hurst/Volume)
   * 10-Day Target: Price ± (ATR₁₄ × √10)
   * Stop-Loss: 1D Bollinger Mid-Line or 1.5× ATR
   * Calendar Risk: List any known token unlocks (>1% supply) or macro dates (CPI, FOMC, etc.) in the next 10 days

Be precise, mechanical, and quantitative. Rank by overall conviction score.`;

  const response = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 1800,
      system: 'You are a senior cryptocurrency quantitative analyst with expertise in perpetual futures, technical analysis, and systematic trading. Be precise, data-driven, and mechanical in your analysis. Always follow the exact output format requested.',
      messages: [{ role: 'user', content: prompt }]
    })
  });

  if (!response.ok) {
    const err = await response.json().catch(() => ({}));
    throw new Error(`Claude API error ${response.status}: ${err.error?.message || 'Unknown'}`);
  }

  const data = await response.json();
  return data.content.map(b => b.text || '').join('');
}

