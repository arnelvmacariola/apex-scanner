<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>APEX | Crypto Breakout Scanner</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap');

  :root {
    --bg: #080c12;
    --surface: #0d1420;
    --surface2: #111c2e;
    --border: #1a2a42;
    --accent: #00e5ff;
    --accent2: #ff6b35;
    --green: #00ff9d;
    --red: #ff3d71;
    --yellow: #ffd60a;
    --text: #e8f4fd;
    --muted: #4a6a8a;
    --grid: rgba(0,229,255,0.03);
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Space Mono', monospace;
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Animated grid background */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(var(--grid) 1px, transparent 1px),
      linear-gradient(90deg, var(--grid) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  body::after {
    content: '';
    position: fixed;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(ellipse at 30% 20%, rgba(0,229,255,0.04) 0%, transparent 50%),
                radial-gradient(ellipse at 70% 80%, rgba(255,107,53,0.04) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
    animation: bgPulse 8s ease-in-out infinite alternate;
  }

  @keyframes bgPulse {
    0% { transform: scale(1) rotate(0deg); }
    100% { transform: scale(1.1) rotate(2deg); }
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 24px 20px;
  }

  /* Header */
  header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 32px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
  }

  .logo {
    display: flex;
    align-items: baseline;
    gap: 10px;
  }

  .logo-main {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 28px;
    letter-spacing: 6px;
    color: var(--accent);
    text-shadow: 0 0 30px rgba(0,229,255,0.4);
  }

  .logo-sub {
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 2px;
  }

  .status-bar {
    display: flex;
    gap: 20px;
    align-items: center;
    font-size: 10px;
    color: var(--muted);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 8px var(--green);
    animation: pulse 2s infinite;
    display: inline-block;
    margin-right: 4px;
  }

  .status-dot.inactive { background: var(--muted); box-shadow: none; animation: none; }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  /* Controls Panel */
  .controls {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 24px;
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    gap: 16px;
    align-items: end;
  }

  .control-group label {
    display: block;
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--muted);
    margin-bottom: 8px;
    text-transform: uppercase;
  }

  .control-group input, .control-group select {
    width: 100%;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 10px 14px;
    color: var(--text);
    font-family: 'Space Mono', monospace;
    font-size: 12px;
    outline: none;
    transition: border-color 0.2s;
  }

  .control-group input:focus, .control-group select:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px rgba(0,229,255,0.1);
  }

  .api-key-row {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 12px;
    align-items: end;
  }

  /* Scan Button */
  .scan-btn {
    background: var(--accent);
    color: var(--bg);
    border: none;
    border-radius: 4px;
    padding: 11px 28px;
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 2px;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
    text-transform: uppercase;
  }

  .scan-btn:hover:not(:disabled) {
    background: #33ecff;
    box-shadow: 0 0 20px rgba(0,229,255,0.4);
    transform: translateY(-1px);
  }

  .scan-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    transform: none;
  }

  /* Progress */
  .progress-section {
    display: none;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 24px;
  }

  .progress-section.active { display: block; }

  .progress-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--muted);
    text-transform: uppercase;
  }

  .progress-bar-wrap {
    background: var(--bg);
    border-radius: 2px;
    height: 3px;
    margin-bottom: 14px;
    overflow: hidden;
  }

  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent), var(--green));
    border-radius: 2px;
    transition: width 0.4s ease;
    box-shadow: 0 0 10px rgba(0,229,255,0.5);
  }

  .progress-log {
    font-size: 11px;
    color: var(--muted);
    max-height: 80px;
    overflow-y: auto;
    line-height: 1.8;
  }

  .progress-log .log-line { display: block; }
  .progress-log .log-line.ok { color: var(--green); }
  .progress-log .log-line.warn { color: var(--yellow); }
  .progress-log .log-line.err { color: var(--red); }

  /* Metrics Row */
  .metrics-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
    margin-bottom: 24px;
  }

  .metric-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 16px;
    text-align: center;
    transition: border-color 0.3s;
  }

  .metric-card:hover { border-color: rgba(0,229,255,0.3); }

  .metric-val {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 26px;
    color: var(--accent);
    line-height: 1;
    margin-bottom: 6px;
  }

  .metric-label {
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--muted);
    text-transform: uppercase;
  }

  /* Results Grid */
  .results-section { display: none; }
  .results-section.active { display: block; }

  .section-title {
    font-family: 'Syne', sans-serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 3px;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* Scan Results Table */
  .scan-table-wrap {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 24px;
  }

  .scan-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 11px;
  }

  .scan-table th {
    background: var(--surface2);
    padding: 10px 14px;
    text-align: left;
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--muted);
    text-transform: uppercase;
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }

  .scan-table td {
    padding: 10px 14px;
    border-bottom: 1px solid rgba(26,42,66,0.5);
    vertical-align: middle;
  }

  .scan-table tr:last-child td { border-bottom: none; }
  .scan-table tr:hover td { background: rgba(0,229,255,0.02); }

  .ticker-cell {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    color: var(--text);
    font-size: 13px;
  }

  .tag {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 3px;
    font-size: 9px;
    letter-spacing: 1px;
    font-weight: 700;
  }

  .tag-long { background: rgba(0,255,157,0.12); color: var(--green); border: 1px solid rgba(0,255,157,0.2); }
  .tag-short { background: rgba(255,61,113,0.12); color: var(--red); border: 1px solid rgba(255,61,113,0.2); }
  .tag-pass { background: rgba(0,255,157,0.08); color: var(--green); }
  .tag-fail { background: rgba(255,61,113,0.08); color: var(--red); }

  .score-bar-wrap {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .score-bar {
    flex: 1;
    height: 4px;
    background: var(--bg);
    border-radius: 2px;
    overflow: hidden;
    max-width: 80px;
  }

  .score-bar-fill {
    height: 100%;
    border-radius: 2px;
  }

  .hurst-val { color: var(--accent); }
  .vol-val { color: var(--yellow); }

  /* AI Analysis Panel */
  .ai-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 24px;
  }

  .ai-panel-header {
    background: var(--surface2);
    padding: 14px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--border);
  }

  .ai-panel-title {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 1px;
    color: var(--accent);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ai-badge {
    font-size: 9px;
    padding: 2px 8px;
    background: rgba(0,229,255,0.1);
    border: 1px solid rgba(0,229,255,0.2);
    border-radius: 20px;
    color: var(--accent);
    letter-spacing: 1px;
  }

  .ai-panel-body {
    padding: 24px;
    font-size: 12px;
    line-height: 1.9;
    color: var(--text);
    white-space: pre-wrap;
    min-height: 200px;
    position: relative;
  }

  .ai-thinking {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--muted);
    font-size: 11px;
  }

  .thinking-dots span {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
    margin: 0 2px;
    animation: blink 1.2s infinite;
  }

  .thinking-dots span:nth-child(2) { animation-delay: 0.2s; }
  .thinking-dots span:nth-child(3) { animation-delay: 0.4s; }

  @keyframes blink {
    0%, 80%, 100% { opacity: 0.2; }
    40% { opacity: 1; }
  }

  /* Setup Cards */
  .setups-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }

  .setup-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 20px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s, transform 0.2s;
  }

  .setup-card:hover {
    border-color: rgba(0,229,255,0.3);
    transform: translateY(-2px);
  }

  .setup-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
  }

  .setup-card.long::before { background: linear-gradient(90deg, var(--green), transparent); }
  .setup-card.short::before { background: linear-gradient(90deg, var(--red), transparent); }

  .setup-rank {
    position: absolute;
    top: 14px;
    right: 16px;
    font-family: 'Syne', sans-serif;
    font-size: 32px;
    font-weight: 800;
    color: rgba(255,255,255,0.04);
  }

  .setup-ticker {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 20px;
    margin-bottom: 8px;
  }

  .setup-meta {
    display: flex;
    gap: 8px;
    margin-bottom: 14px;
    flex-wrap: wrap;
  }

  .setup-conviction {
    font-size: 10px;
    color: var(--muted);
    margin-bottom: 12px;
  }

  .conviction-stars {
    display: inline-flex;
    gap: 2px;
  }

  .star { color: var(--yellow); font-size: 10px; }
  .star.empty { color: var(--border); }

  .setup-body {
    font-size: 11px;
    color: rgba(232,244,253,0.75);
    line-height: 1.8;
    border-top: 1px solid var(--border);
    padding-top: 12px;
    margin-top: 12px;
  }

  .setup-targets {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    margin-top: 12px;
  }

  .target-box {
    background: var(--bg);
    border-radius: 4px;
    padding: 8px 10px;
    font-size: 10px;
  }

  .target-box-label { color: var(--muted); margin-bottom: 3px; font-size: 9px; letter-spacing: 1px; }
  .target-box-val { font-family: 'Syne', sans-serif; font-weight: 700; font-size: 13px; }
  .target-box-val.up { color: var(--green); }
  .target-box-val.down { color: var(--red); }

  .setup-risk {
    margin-top: 10px;
    font-size: 10px;
    padding: 8px 10px;
    background: rgba(255,61,113,0.06);
    border: 1px solid rgba(255,61,113,0.12);
    border-radius: 4px;
    color: var(--red);
  }

  .setup-calendar {
    margin-top: 10px;
    font-size: 10px;
    padding: 8px 10px;
    background: rgba(255,214,10,0.06);
    border: 1px solid rgba(255,214,10,0.1);
    border-radius: 4px;
    color: var(--yellow);
    line-height: 1.6;
  }

  /* Filtered Out */
  .filtered-section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 20px;
    margin-bottom: 24px;
  }

  .filtered-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
  }

  .filtered-chip {
    padding: 4px 12px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 20px;
    font-size: 10px;
    color: var(--muted);
  }

  .filtered-chip span { color: var(--red); margin-left: 4px; }

  /* Error */
  .error-box {
    background: rgba(255,61,113,0.08);
    border: 1px solid rgba(255,61,113,0.2);
    border-radius: 8px;
    padding: 16px 20px;
    color: var(--red);
    font-size: 12px;
    margin-bottom: 24px;
    display: none;
  }

  .error-box.active { display: block; }

  /* Timestamp */
  .scan-footer {
    text-align: center;
    font-size: 10px;
    color: var(--muted);
    padding: 16px;
    border-top: 1px solid var(--border);
    letter-spacing: 1px;
  }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 4px; }
  ::-webkit-scrollbar-track { background: var(--bg); }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

  @media (max-width: 768px) {
    .controls { grid-template-columns: 1fr; }
    .api-key-row { grid-template-columns: 1fr; }
    .metrics-row { grid-template-columns: repeat(2, 1fr); }
    .setups-grid { grid-template-columns: 1fr; }
    .scan-table { font-size: 10px; }
  }
</style>
</head>
<body>
<div class="container">

  <!-- Header -->
  <header>
    <div class="logo">
      <span class="logo-main">APEX</span>
      <span class="logo-sub">BREAKOUT SCANNER v2.0</span>
    </div>
    <div class="status-bar">
      <span><span class="status-dot" id="apiDot" style="background:var(--muted);box-shadow:none;animation:none"></span>CLAUDE API</span>
      <span><span class="status-dot" id="dataDot" style="background:var(--muted);box-shadow:none;animation:none"></span>OKX FEED</span>
      <span id="lastScanTime">NO SCAN</span>
    </div>
  </header>

  <!-- Controls -->
  <div class="controls">
    <div class="control-group api-key-row">
      <div class="control-group" style="margin:0">
        <label>Anthropic API Key</label>
        <input type="password" id="apiKey" placeholder="sk-ant-..." autocomplete="off" />
      </div>
      <div>
        <label>&nbsp;</label>
        <button class="scan-btn" id="scanBtn" onclick="runScan()">▶ RUN SCAN</button>
      </div>
    </div>
    <div class="control-group">
      <label>Asset Limit (Top N by Volume)</label>
      <select id="assetLimit">
        <option value="20">Top 20</option>
        <option value="30" selected>Top 30</option>
        <option value="50">Top 50</option>
      </select>
    </div>
    <div class="control-group">
      <label>Funding Rate Cutoff</label>
      <select id="fundingCutoff">
        <option value="0.05" selected>±0.05% (Standard)</option>
        <option value="0.08">±0.08% (Relaxed)</option>
        <option value="0.03">±0.03% (Strict)</option>
      </select>
    </div>
    <div class="control-group">
      <label>Hurst Threshold</label>
      <select id="hurstThreshold">
        <option value="0.55" selected>H > 0.55 (Standard)</option>
        <option value="0.60">H > 0.60 (Strong Trend)</option>
        <option value="0.50">H > 0.50 (Permissive)</option>
      </select>
    </div>
  </div>

  <!-- Error Box -->
  <div class="error-box" id="errorBox"></div>

  <!-- Progress -->
  <div class="progress-section" id="progressSection">
    <div class="progress-header">
      <span>SCAN PROGRESS</span>
      <span id="progressPct">0%</span>
    </div>
    <div class="progress-bar-wrap">
      <div class="progress-bar-fill" id="progressBar" style="width:0%"></div>
    </div>
    <div class="progress-log" id="progressLog"></div>
  </div>

  <!-- Metrics Row -->
  <div class="metrics-row" id="metricsRow" style="display:none">
    <div class="metric-card">
      <div class="metric-val" id="mScanned">—</div>
      <div class="metric-label">Pairs Scanned</div>
    </div>
    <div class="metric-card">
      <div class="metric-val" id="mPassed">—</div>
      <div class="metric-label">Passed Filters</div>
    </div>
    <div class="metric-card">
      <div class="metric-val" id="mLong" style="color:var(--green)">—</div>
      <div class="metric-label">Long Setups</div>
    </div>
    <div class="metric-card">
      <div class="metric-val" id="mShort" style="color:var(--red)">—</div>
      <div class="metric-label">Short Setups</div>
    </div>
  </div>

  <!-- Results -->
  <div class="results-section" id="resultsSection">

    <!-- Scan Table -->
    <div class="section-title">RAW SCAN DATA — ALL PAIRS</div>
    <div class="scan-table-wrap">
      <table class="scan-table" id="scanTable">
        <thead>
          <tr>
            <th>Ticker</th>
            <th>Signal</th>
            <th>Price</th>
            <th>30D Break</th>
            <th>Hurst (est)</th>
            <th>BB Squeeze</th>
            <th>Vol Ratio</th>
            <th>Funding</th>
            <th>Filter</th>
          </tr>
        </thead>
        <tbody id="scanTableBody"></tbody>
      </table>
    </div>

    <!-- Claude AI Analysis -->
    <div class="section-title">CLAUDE AI — QUANTITATIVE ANALYSIS</div>
    <div class="ai-panel">
      <div class="ai-panel-header">
        <div class="ai-panel-title">
          <span>SENIOR QUANT ANALYST OUTPUT</span>
          <span class="ai-badge">CLAUDE SONNET 4</span>
        </div>
        <div style="font-size:10px;color:var(--muted)" id="aiModel">—</div>
      </div>
      <div class="ai-panel-body" id="aiOutput">
        <div class="ai-thinking">
          <span>Awaiting scan data</span>
        </div>
      </div>
    </div>

    <!-- Parsed Setups -->
    <div class="section-title" id="setupsTitle" style="display:none">TOP SETUPS — PARSED</div>
    <div class="setups-grid" id="setupsGrid"></div>

    <!-- Filtered Out -->
    <div class="section-title">DISQUALIFIED — FAILED FILTERS</div>
    <div class="filtered-section">
      <div style="font-size:10px;color:var(--muted);letter-spacing:1px;">ASSETS ELIMINATED BY HARD GATES</div>
      <div class="filtered-chips" id="filteredChips"></div>
    </div>

  </div>

  <div class="scan-footer" id="scanFooter">APEX BREAKOUT SCANNER — LIVE OKX DATA + CLAUDE AI — FOR RESEARCH PURPOSES ONLY</div>

</div>

<script>
// ─────────────────────────────────────────────
// UTILITIES
// ─────────────────────────────────────────────

function log(msg, type = '') {
  const el = document.getElementById('progressLog');
  const line = document.createElement('span');
  line.className = `log-line ${type}`;
  line.textContent = `[${new Date().toLocaleTimeString()}] ${msg}`;
  el.appendChild(line);
  el.appendChild(document.createElement('br'));
  el.scrollTop = el.scrollHeight;
}

function setProgress(pct, msg) {
  document.getElementById('progressBar').style.width = pct + '%';
  document.getElementById('progressPct').textContent = Math.round(pct) + '%';
  if (msg) log(msg);
}

function sleep(ms) { return new Promise(r => setTimeout(r, ms)); }

// ─────────────────────────────────────────────
// DATA FETCHING — OKX PUBLIC API (no auth needed)
// ─────────────────────────────────────────────

// CORS proxy list - tries each one until success
const CORS_PROXIES = [
  'https://corsproxy.io/?',
  'https://api.allorigins.win/raw?url=',
  'https://cors-anywhere.herokuapp.com/',
];

async function fetchOKX(path) {
  const targetUrl = 'https://www.okx.com' + path;
  let lastError;
  for (const proxy of CORS_PROXIES) {
    try {
      const url = proxy + encodeURIComponent(targetUrl);
      const res = await fetch(url, { headers: { 'x-requested-with': 'XMLHttpRequest' } });
      if (!res.ok) continue;
      const j = await res.json();
      if (j.code !== '0') throw new Error(`OKX API error: ${j.msg}`);
      return j.data;
    } catch(e) {
      lastError = e;
      continue;
    }
  }
  throw new Error('All proxies failed: ' + (lastError?.message || 'unknown'));
}

async function getTopPairs(limit) {
  // Get top USDT-SWAP pairs by open interest (proxy for volume rank)
  const tickers = await fetchOKX('/api/v5/market/tickers?instType=SWAP');
  const usdt = tickers
    .filter(t => t.instId.endsWith('-USDT-SWAP'))
    .map(t => ({ instId: t.instId, vol24h: parseFloat(t.volCcy24h) || 0, last: parseFloat(t.last) }))
    .sort((a, b) => b.vol24h - a.vol24h)
    .slice(0, limit);
  return usdt;
}

async function getCandles(instId, bar, limit) {
  // bar: '1D', '4H', etc.
  const data = await fetchOKX(`/api/v5/market/candles?instId=${instId}&bar=${bar}&limit=${limit}`);
  // [ts, o, h, l, c, vol, volCcy, volCcyQuote, confirm]
  return data.map(c => ({
    ts: parseInt(c[0]),
    o: parseFloat(c[1]),
    h: parseFloat(c[2]),
    l: parseFloat(c[3]),
    c: parseFloat(c[4]),
