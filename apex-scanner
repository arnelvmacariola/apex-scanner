function renderScanTable(results, filtered) {
  const tbody = document.getElementById('scanTableBody');
  tbody.innerHTML = '';

  results.forEach(r => {
    const tr = document.createElement('tr');
    const scoreColor = r.volRatio >= 2.5 ? 'var(--green)' : r.volRatio >= 1.5 ? 'var(--yellow)' : 'var(--muted)';
    const hurstColor = r.hurst >= 0.65 ? 'var(--green)' : r.hurst >= 0.55 ? 'var(--accent)' : 'var(--yellow)';

    tr.innerHTML = `
      <td class="ticker-cell">${r.ticker}</td>
      <td><span class="tag tag-${r.signal.toLowerCase()}">${r.signal}</span></td>
      <td>$${r.price.toFixed(4)}</td>
      <td><span class="tag tag-pass">✓ BREACH</span></td>
      <td style="color:${hurstColor};font-weight:700">${r.hurst.toFixed(3)}</td>
      <td>${r.bbSqueeze ? `<span class="tag tag-pass">✓ ${r.bbSqueezeDays}D</span>` : '<span class="tag tag-fail">—</span>'}</td>
      <td style="color:${scoreColor};font-weight:700">${r.volRatio.toFixed(2)}×</td>
      <td style="color:${Math.abs(r.fundingRate) > 0.03 ? 'var(--yellow)' : 'var(--muted)'}">${r.fundingRate.toFixed(4)}%</td>
      <td><span class="tag tag-pass">PASS</span></td>
    `;
    tbody.appendChild(tr);
  });

  // Filtered out chips
  const chips = document.getElementById('filteredChips');
  chips.innerHTML = '';
  filtered.forEach(f => {
    const chip = document.createElement('div');
    chip.className = 'filtered-chip';
    chip.innerHTML = `${f.ticker}<span>✗ ${f.reason}</span>`;
    chips.appendChild(chip);
  });
}

function parseAndRenderSetups(aiText, scanData) {
  // Parse top setups from Claude's output
  const tickerMatches = [...aiText.matchAll(/\[([A-Z0-9]+)\]\s*\|\s*\[(LONG|SHORT)\]\s*\|\s*\[CONVICTION\s*(\d+)/g)];
  if (tickerMatches.length === 0) {
    // Try simpler pattern
    const alt = [...aiText.matchAll(/([A-Z0-9]{2,10})\s*\|\s*(LONG|SHORT)\s*\|\s*(\d+)/g)];
    if (alt.length === 0) return;
    renderSetupCards(alt.map(m => ({ ticker: m[1], signal: m[2], conviction: parseInt(m[3]) })), aiText, scanData);
    return;
  }
  renderSetupCards(tickerMatches.map(m => ({ ticker: m[1], signal: m[2], conviction: parseInt(m[3]) })), aiText, scanData);
}

function renderSetupCards(setups, fullText, scanData) {
  if (!setups || setups.length === 0) return;
  document.getElementById('setupsTitle').style.display = 'flex';
  const grid = document.getElementById('setupsGrid');
  grid.innerHTML = '';

  setups.slice(0, 3).forEach((s, i) => {
    const scanEntry = scanData.find(r => r.ticker === s.ticker) || {};
    const atr = scanEntry.atr || 0;
    const price = scanEntry.price || 0;
    const target = s.signal === 'LONG' ? price + atr * Math.sqrt(10) : price - atr * Math.sqrt(10);
    const sl = s.signal === 'LONG' ? price - atr * 1.5 : price + atr * 1.5;

    const stars = Array(10).fill(0).map((_, j) =>
      `<span class="star ${j < s.conviction ? '' : 'empty'}">★</span>`).join('');

    // Extract relevant section from AI text for this ticker
    const tickerIdx = fullText.indexOf(s.ticker);
    const snippet = tickerIdx >= 0
      ? fullText.substring(tickerIdx, tickerIdx + 400).split('\n').slice(0, 6).join('\n')
      : '';

    const card = document.createElement('div');
    card.className = `setup-card ${s.signal.toLowerCase()}`;
    card.innerHTML = `
      <div class="setup-rank">#${i+1}</div>
      <div class="setup-ticker" style="color:${s.signal==='LONG'?'var(--green)':'var(--red)'}">${s.ticker}</div>
      <div class="setup-meta">
        <span class="tag tag-${s.signal.toLowerCase()}">${s.signal}</span>
        ${scanEntry.bbSqueeze ? '<span class="tag" style="background:rgba(0,229,255,0.1);color:var(--accent);border:1px solid rgba(0,229,255,0.2)">BB SQUEEZE</span>' : ''}
        ${(scanEntry.volRatio||0) >= 2.5 ? '<span class="tag" style="background:rgba(255,214,10,0.1);color:var(--yellow);border:1px solid rgba(255,214,10,0.2)">VOL SURGE</span>' : ''}
      </div>
      <div class="setup-conviction">
        CONVICTION: <div class="conviction-stars">${stars}</div> ${s.conviction}/10
      </div>
      <div class="setup-body">H=${(scanEntry.hurst||0).toFixed(3)} | Vol×${(scanEntry.volRatio||0).toFixed(1)} | Fund=${(scanEntry.fundingRate||0).toFixed(4)}%</div>
      <div class="setup-targets">
        <div class="target-box">
          <div class="target-box-label">10D TARGET</div>
          <div class="target-box-val up">${price ? '$'+target.toFixed(4) : 'See AI'}</div>
        </div>
        <div class="target-box">
          <div class="target-box-label">STOP LOSS</div>
          <div class="target-box-val down">${price ? '$'+sl.toFixed(4) : 'See AI'}</div>
        </div>
      </div>
      <div class="setup-risk">⚠ ATR(14) = ${atr > 0 ? '$'+atr.toFixed(4) : 'See AI output'} | 1.5× ATR stop</div>
      <div class="setup-calendar">📅 Check AI output for calendar risk events</div>
    `;
    grid.appendChild(card);
  });
}

function showError(msg) {
  const el = document.getElementById('errorBox');
  el.textContent = '⚠ ' + msg;
  el.classList.add('active');
}
